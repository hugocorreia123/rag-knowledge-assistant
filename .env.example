# Groq API — get your key from https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# LLM provider selection — supported: groq, azure_openai, openai
LLM_PROVIDER=groq

# Optional: Azure OpenAI (only needed if LLM_PROVIDER=azure_openai)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=

# Optional: OpenAI (only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=